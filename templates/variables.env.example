# Template Variables
# Copy this file to ~/dotfiles/variables.env and fill in your values.
# This file is git-ignored and should never be committed.
#
# These values replace {{PLACEHOLDER}} in .template files during setup.

# Git configuration
GIT_NAME="Your Name"
GIT_EMAIL="your.email@example.com"

# SSH key paths
KEELVAR_KEY_PATH="~/.ssh/id_rsa_work"
PERSONAL_KEY_PATH="~/.ssh/id_rsa_personal"

# Python/Neovim
PYTHON_VENV_PATH="~/venvs/.nvim-venv"
